{
  "name": "bookedoncall-website",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.5.0 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint --max-warnings=0 .",
    "security:audit": "npm audit --omit=dev --audit-level=moderate",
    "security:secrets": "node ./scripts/secret-scan.cjs",
    "verify:content": "node ./scripts/verify-content.mjs",
    "verify:runtime": "node ./scripts/verify-runtime.mjs",
    "verify:seo": "node ./scripts/verify-postbuild-seo.mjs",
    "verify:security": "npm run security:audit && npm run security:secrets",
    "sync:monorepo-truth": "node ./scripts/sync-monorepo-public-truth.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next": "^16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
